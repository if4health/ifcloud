<div id="content">
    <div id="card">
        <form id="json_form">
            <div class="line">
                <h2>Formulário Json</h2>
            </div>

            <div class="line">
                <label>Resource Type</label>
                <select id="resource_type" name="resourceType">
                    <option value="Observation">Observation</option>
                    <option value="Patient">Patient</option>
                </select>
            </div>

            <div class="line">
                <label>Resource Id</label>
                <input id="id" type="text" name="id" />
            </div>

            <div class="line">
                <label>Script Name</label>
                <input id="script_name" type="text" name="scriptName">
            </div>

            <!-- Tipo de requisição -->
            <div class="line">
                <label>Tipo de Requisição</label>
                <select id="type_request" name="typeRequest" onchange="handleTypeRequestChange()">
                    <option value="byId">Por ID</option>
                    <option value="byIdAndMinute">Por ID e Minuto</option>
                    <option value="byIdAndMinuteInterval">Por ID e Intervalo de Minutos</option>
                </select>
            </div>

            <!-- Campo: minuto único (byIdAndMinute) -->
            <div class="line" id="field_minute" style="display: none;">
                <label>Minuto <small class="text-muted">(maior ou igual a 0)</small></label>
                <input id="minute" type="number" name="minute" min="0" placeholder="Ex: 3">
                <span class="field-error" id="err_minute" style="display:none; color: red; font-size: 12px;">Minuto deve ser maior ou igual a 0</span>
            </div>

            <!-- Campos: intervalo de minutos (byIdAndMinuteInterval) -->
            <div class="line" id="field_interval" style="display: none;">
                <label>Minuto Inicial <small class="text-muted">(maior ou igual a 0)</small></label>
                <input id="initial_minute" type="number" name="initialMinute" min="0" placeholder="Ex: 1">
                <span class="field-error" id="err_initial_minute" style="display:none; color: red; font-size: 12px;">Deve ser maior ou igual a 0</span>
                <label style="margin-top: 8px;">Minuto Final <small class="text-muted">(maior que o inicial)</small></label>
                <input id="final_minute" type="number" name="finalMinute" min="1" placeholder="Ex: 5">
                <span class="field-error" id="err_final_minute" style="display:none; color: red; font-size: 12px;">Deve ser maior que o minuto inicial</span>
            </div>

            <!-- Primeira instância de componentData -->
            <div class="line componentData">
                <label>Component Index</label>
                <input type="text" name="componentIndex[]">
                <label>Change Field</label>
                <input type="text" name="changeField[]">
            </div>

            <div class="line">
                <label>Return Only Fields Component</label>
                <select id="returnOnlyFieldsComponents" name="returnOnlyFieldsComponents">
                    <option value="false">false</option>
                    <option value="true">true</option>
                </select>
            </div>

            <div id="actions" class="line">
                <button type="button" id="addComponent" class="btn">Adicionar Componente</button>
            </div>

            <div id="send" class="line">
                <input type="submit" id="btn_send" value="Enviar">
            </div>
        </form>
    </div>
</div>

<!-- Loading -->
<div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center;">
    <div class="spinner-border text-light" role="status" style="width: 4rem; height: 4rem;">
        <span class="visually-hidden">Carregando...</span>
    </div>
</div>

<!-- Response Modal -->
<div class="modal fade" id="responseModal" tabindex="-1" aria-labelledby="responseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" style="max-width: 75vw;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="responseModalLabel">Resposta da Requisição</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                <div id="responseContent"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<script>
const addComponentButton = document.getElementById('addComponent');
const form = document.getElementById('json_form');
const returnOnlyFieldsComponents = document.querySelector('.line select#returnOnlyFieldsComponents');
const loadingOverlay = document.getElementById('loadingOverlay');

// ─── Tipo de requisição ───────────────────────────────────────────────────────

/**
 * Mostra/oculta os campos de minuto e intervalo
 * conforme o typeRequest selecionado.
 */
function handleTypeRequestChange() {
    const type = document.getElementById('type_request').value;
    const fieldMinute   = document.getElementById('field_minute');
    const fieldInterval = document.getElementById('field_interval');

    fieldMinute.style.display   = type === 'byIdAndMinute'         ? 'flex' : 'none';
    fieldInterval.style.display = type === 'byIdAndMinuteInterval' ? 'flex' : 'none';

    // Limpa erros e valores ao trocar de tipo
    clearMinuteErrors();
    document.getElementById('minute').value        = '';
    document.getElementById('initial_minute').value = '';
    document.getElementById('final_minute').value   = '';
}

// ─── Validações de minuto ─────────────────────────────────────────────────────

function clearMinuteErrors() {
    ['err_minute', 'err_initial_minute', 'err_final_minute'].forEach(id => {
        document.getElementById(id).style.display = 'none';
    });
}

/**
 * Valida os campos de minuto conforme o tipo de requisição.
 * Lança erro descritivo para cada campo inválido.
 * @returns {boolean} true se válido
 */
function validateMinuteFields(type) {
    clearMinuteErrors();
    let valid = true;

    if (type === 'byIdAndMinute') {
        const minute = parseInt(document.getElementById('minute').value, 10);
        if (isNaN(minute) || minute < 0) {
            document.getElementById('err_minute').style.display = 'block';
            valid = false;
        }
    }

    if (type === 'byIdAndMinuteInterval') {
        const ini = parseInt(document.getElementById('initial_minute').value, 10);
        const fin = parseInt(document.getElementById('final_minute').value, 10);

        if (isNaN(ini) || ini < 0) {
            document.getElementById('err_initial_minute').style.display = 'block';
            valid = false;
        }

        if (isNaN(fin) || fin <= 0) {
            document.getElementById('err_final_minute').style.display = 'block';
            valid = false;
        }

        // Só valida intervalo se ambos os valores são números válidos
        if (!isNaN(ini) && !isNaN(fin) && ini >= 0 && fin > 0 && fin <= ini) {
            document.getElementById('err_final_minute').textContent = 'Deve ser maior que o minuto inicial';
            document.getElementById('err_final_minute').style.display = 'block';
            valid = false;
        }
    }

    return valid;
}

// ─── Campos extras por tipo de requisição ─────────────────────────────────────

/**
 * Monta os campos extras (minute, initialMinute, finalMinute)
 * no payload conforme o typeRequest.
 * @param {string} type
 * @returns {Object} campos extras a serem merged no payload
 */
function buildMinuteFields(type) {
    if (type === 'byIdAndMinute') {
        return { minute: parseInt(document.getElementById('minute').value, 10) };
    }

    if (type === 'byIdAndMinuteInterval') {
        return {
            initialMinute: parseInt(document.getElementById('initial_minute').value, 10),
            finalMinute:   parseInt(document.getElementById('final_minute').value, 10),
        };
    }

    return {};
}

// ─── Componentes dinâmicos ────────────────────────────────────────────────────

addComponentButton.addEventListener('click', () => {
    const newComponentData = document.createElement('div');
    newComponentData.classList.add('line', 'componentData');
    newComponentData.innerHTML = `
        <label>Component Index</label>
        <input type="text" name="componentIndex[]">
        <label>Change Field</label>
        <input type="text" name="changeField[]">
        <button type="button" class="removeComponent btn">Remover</button>
    `;
    form.insertBefore(newComponentData, returnOnlyFieldsComponents.parentElement);

    newComponentData.querySelector('.removeComponent').addEventListener('click', () => {
        if (document.querySelectorAll('.componentData').length > 1) {
            newComponentData.remove();
        } else {
            alert('O formulário deve conter pelo menos um componente.');
        }
    });
});

document.querySelectorAll('.componentData .removeComponent').forEach(button => {
    button.addEventListener('click', function () {
        if (document.querySelectorAll('.componentData').length > 1) {
            this.parentElement.remove();
        } else {
            alert('O formulário deve conter pelo menos um componente.');
        }
    });
});

// ─── Submit ───────────────────────────────────────────────────────────────────

form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const type = document.getElementById('type_request').value;

    if (!validateMinuteFields(type)) return;

    const formData = new FormData(form);

    const componentIndexes = formData.getAll('componentIndex[]');
    const changeFields     = formData.getAll('changeField[]');

    const components = [];
    for (let i = 0; i < componentIndexes.length; i++) {
        if (componentIndexes[i] || changeFields[i]) {
            components.push({
                index:       componentIndexes[i],
                changeField: changeFields[i],
            });
        }
    }

    const data = {
        typeRequest:                 type,
        resourceType:                formData.get('resourceType'),
        id:                          formData.get('id'),
        scriptName:                  formData.get('scriptName'),
        returnOnlyFieldsComponents:  formData.get('returnOnlyFieldsComponents') === 'true',
        components,
        ...buildMinuteFields(type),  // ← campos de minuto conforme o tipo
    };

    loadingOverlay.style.display = 'flex';

    try {
        const response = await fetch('/ifcloud/run_script/operation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
        });

        const result = await response.json();
        loadingOverlay.style.display = 'none';

        const responseContent = document.getElementById('responseContent');
        const modalTitle      = document.getElementById('responseModalLabel');

        if (result.status === 'error' || !response.ok) {
            modalTitle.textContent = 'Erro na Requisição';
            modalTitle.className   = 'modal-title text-danger';
            responseContent.innerHTML = `
                <div class="alert alert-danger" role="alert">
                    <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> ${result.error || 'Erro'}</h5>
                    <hr>
                    <p class="mb-0"><strong>Mensagem:</strong> ${result.message || 'Ocorreu um erro inesperado'}</p>
                    ${result.details ? `<p class="mb-0 mt-2"><strong>Detalhes:</strong> ${result.details}</p>` : ''}
                </div>
                <details>
                    <summary style="cursor: pointer; color: #0d6efd;">Ver resposta completa (JSON)</summary>
                    <pre style="background-color: #f8f9fa; padding: 10px; border-radius: 5px; margin-top: 10px;">${JSON.stringify(result, null, 2)}</pre>
                </details>
            `;
        } else {
            modalTitle.textContent = 'Resposta da Requisição';
            modalTitle.className   = 'modal-title text-success';
            responseContent.innerHTML = `
                <pre style="background-color: #f5f5f5; padding: 15px; border-radius: 5px; max-height: 60vh; max-width: 100%; overflow-x: auto; overflow-y: auto; word-wrap: break-word; white-space: pre-wrap;">${JSON.stringify(result, null, 2)}</pre>
            `;
        }

        new bootstrap.Modal(document.getElementById('responseModal')).show();

    } catch (error) {
        loadingOverlay.style.display = 'none';

        const responseContent = document.getElementById('responseContent');
        const modalTitle      = document.getElementById('responseModalLabel');

        modalTitle.textContent = 'Erro de Conexão';
        modalTitle.className   = 'modal-title text-danger';
        responseContent.innerHTML = `
            <div class="alert alert-danger" role="alert">
                <h5 class="alert-heading"><i class="bi bi-x-circle-fill"></i> Erro de Conexão</h5>
                <hr>
                <p class="mb-0"><strong>Mensagem:</strong> Não foi possível conectar ao servidor</p>
                <p class="mb-0 mt-2"><strong>Detalhes:</strong> ${error.message}</p>
            </div>
        `;
        new bootstrap.Modal(document.getElementById('responseModal')).show();
    }
});
</script>